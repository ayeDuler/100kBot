async def buy(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    if len(context.args) < 2:
        await send_text(update, "Usage: /buy <mint> <sol_amount>")
        return
    mint, sol_amount = context.args[0], float(context.args[1])
    price = STATE.watchlist.get(mint, TokenState(mint=mint)).last_price_sol or 0.0000001
    result = execute_trade("buy", mint, sol_amount, denominated_in_sol=True)
    fill = apply_paper_fill("buy", mint, sol_amount, price)
    await send_text(update, f"Buy result: `{json.dumps({'trade': result, 'fill': fill}, default=str)[:3500]}`")


async def sell(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    if len(context.args) < 1:
        await send_text(update, "Usage: /sell <mint> [100%]")
        return
    mint = context.args[0]
    amount = context.args[1] if len(context.args) > 1 else "100%"
    price = STATE.watchlist.get(mint, TokenState(mint=mint)).last_price_sol or 0.0000001
    result = execute_trade("sell", mint, amount, denominated_in_sol=False)
    fill = apply_paper_fill("sell", mint, amount, price)
    await send_text(update, f"Sell result: `{json.dumps({'trade': result, 'fill': fill}, default=str)[:3500]}`")


