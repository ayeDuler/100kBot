        await send_text(update, "No signal yet.")
        return
    ts = best[0]
    verdict = "BUY" if should_auto_buy(ts, STATE) else "WATCH"
    await send_text(update, f"Signal: *{verdict}*\n\n{format_token(ts)}")


async def score_cmd(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    if not context.args:
        await send_text(update, "Usage: /score <mint>")
        return
    mint = context.args[0]
    ts = STATE.watchlist.get(mint)
    if not ts:
        await send_text(update, "Token not tracked.")
        return
    await send_text(update, format_token(ts))


async def rugcheck(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    if not context.args:
        await send_text(update, "Usage: /rugcheck <mint>")
        return
    mint = context.args[0]
    ts = STATE.watchlist.get(mint)
    if not ts:
        await send_text(update, "Token not tracked yet. Add /watch first.")
        return
    await send_text(update, f"Rug risk for `{mint}`: *{ts.risk_score:.1f}*\nNotes: {'; '.join(ts.notes) or 'None'}")


async def dumps(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    worst = sorted(STATE.tracked_wallet_dump_count.items(), key=lambda x: x[1], reverse=True)[:10]
    if not worst:
        await send_text(update, "No dump wallets observed yet.")
        return
    await send_text(update, "\n".join(f"`{w}` â *{c}* early dumps" for w, c in worst))


async def exposure(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    exposure_sol = sum(p.qty * p.last_price_sol for p in STATE.positions.values())
    await send_text(update, f"Approx exposure: *{exposure_sol:.4f} SOL*")


async def stats(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    await send_text(update, f"Tracked tokens: *{len(STATE.watchlist)}*\nTrades seen: *{sum(t.trade_count for t in STATE.watchlist.values())}*")


async def reset(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    STATE.watchlist.clear()
    STATE.positions.clear()
    STATE.trade_history.clear()
    STATE.tracked_wallet_dump_count.clear()
    STATE.paper_cash_sol = 5.0
    STATE.realized_pnl_sol = 0.0
    await send_text(update, "Local state reset")


async def ping(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    await send_text(update, "pong")


async def version(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    await send_text(update, "Starter build v0.1")


async def callback_router(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    query = update.callback_query
    await query.answer()
    mapping = {
        "scan": scan,
        "watchlist": watchlist,
        "portfolio": portfolio,
        "settings": settings,
        "paper": paper,
        "pause": pause,
    }
    handler = mapping.get(query.data)
    if handler:
        await handler(update, context)


def build_app() -> Application:
    app = Application.builder().token(TELEGRAM_BOT_TOKEN).build()
    handlers = {
        "start": start,
        "help": help_cmd,
        "menu": menu,
        "status": status,
        "scan": scan,
        "trending": trending,
        "watchlist": watchlist,
        "top": top,
        "hot": hot,
        "portfolio": portfolio,
        "pnl": pnl,
        "positions": positions,
        "history": history,
        "balance": balance,
        "settings": settings,
        "risk": risk,
        "tp": tp,
        "sl": sl,
        "trailing": trailing,
        "maxpos": maxpos,
        "minscore": minscore,
        "maxrisk": maxrisk,
        "buy": buy,
        "sell": sell,
        "autobuy_on": autobuy_on,
        "autobuy_off": autobuy_off,
        "autosell_on": autosell_on,
        "autosell_off": autosell_off,
        "pause": pause,
        "resume": resume,
        "paper": paper,
        "live": live,
        "watch": watch,
        "unwatch": unwatch,
        "whitelist": whitelist_cmd,
        "blacklist": blacklist_cmd,
        "remove": remove,
        "alerts": alerts,
        "signal": signal_cmd,
        "score": score_cmd,
        "rugcheck": rugcheck,
        "dumps": dumps,
        "exposure": exposure,
        "stats": stats,
        "reset": reset,
        "ping": ping,
        "version": version,
    }
    for name, fn in handlers.items():
        app.add_handler(CommandHandler(name, fn))
    app.add_handler(CallbackQueryHandler(callback_router))
    return app


async def main() -> None:
    if not TELEGRAM_BOT_TOKEN:
        raise RuntimeError("Missing TELEGRAM_BOT_TOKEN")

    app = build_app()
    STATE.ws_task = asyncio.create_task(stream_pump_data())

    stop_event = asyncio.Event()

    def _stop(*_: Any) -> None:
        stop_event.set()

    loop = asyncio.get_running_loop()
    for sig in (signal.SIGINT, signal.SIGTERM):
        try:
            loop.add_signal_handler(sig, _stop)
        except NotImplementedError:
            pass

    await app.initialize()
    await app.start()
    await app.updater.start_polling()
    logger.info("Telegram bot started")

    await stop_event.wait()

    if STATE.ws_task:
        STATE.ws_task.cancel()
        with contextlib.suppress(Exception):
            await STATE.ws_task

    await app.updater.stop()
    await app.stop()
    await app.shutdown()


if __name__ == "__main__":
    import contextlib
    asyncio.run(main())
