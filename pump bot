def is_live() -> bool:
    return LIVE_TRADING and bool(PUMPPORTAL_API_KEY)


def format_token(ts: TokenState) -> str:
    return (
        f"*{ts.symbol}* â `{ts.mint}`\n"
        f"Score: *{ts.score:.1f}* | Risk: *{ts.risk_score:.1f}*\n"
        f"Buys/Sells: *{ts.buy_count}/{ts.sell_count}* | Wallets: *{len(ts.unique_wallets)}*\n"
        f"Price(SOL): *{ts.last_price_sol:.8f}*\n"
        f"Notes: {'; '.join(ts.notes[-3:]) if ts.notes else 'None'}"
    )


def compute_risk_and_score(ts: TokenState, state: BotState) -> None:
    """Heuristic starter model.
    This does NOT replace on-chain holder analysis and contract auditing.
    """
    buys = ts.buy_count
    sells = ts.sell_count
    trades = max(1, ts.trade_count)
    unique_wallets = max(1, len(ts.unique_wallets))

    buy_pressure = min(30.0, (buys / trades) * 30.0)
    wallet_diversity = min(20.0, unique_wallets * 1.2)
    activity_bonus = min(15.0, trades * 0.25)

    # Wallet concentration penalty (starter approximation using observed buy flow)
    total_buy = sum(ts.wallet_buy_volume.values()) or 1.0
    top_wallet_share = max(ts.wallet_buy_volume.values(), default=0.0) / total_buy
    concentration_penalty = min(30.0, top_wallet_share * 50.0)

    # Instant dump penalty: wallets that buy then quickly sell heavy size in observed stream
    early_dump_penalty = 0.0
    for wallet, sells_vol in ts.wallet_sell_volume.items():
        buys_vol = ts.wallet_buy_volume.get(wallet, 0.0)
        if buys_vol > 0 and sells_vol >= buys_vol * 0.75:
            early_dump_penalty += 3.0
            state.tracked_wallet_dump_count[wallet] += 1
            if state.tracked_wallet_dump_count[wallet] >= 3:
                early_dump_penalty += 4.0
    early_dump_penalty = min(25.0, early_dump_penalty)

    sell_pressure_penalty = min(25.0, (sells / trades) * 25.0)

    raw_score = 20.0 + buy_pressure + wallet_diversity + activity_bonus
    risk = 15.0 + concentration_penalty + early_dump_penalty + sell_pressure_penalty
    score = max(0.0, min(100.0, raw_score - (risk * 0.35)))
    risk = max(0.0, min(100.0, risk))

    notes = []
    if top_wallet_share > 0.35:
        notes.append("High buy concentration")
    if early_dump_penalty > 6:
        notes.append("Observed instant-dump wallets")
    if unique_wallets >= 10:
        notes.append("Healthy wallet spread")
    if buys > sells * 2 and buys >= 6:
        notes.append("Positive buy pressure")

    ts.score = score
    ts.risk_score = risk
    ts.notes = notes


def should_auto_buy(ts: TokenState, state: BotState) -> bool:
    if not state.auto_buy_enabled or state.paused:
        return False
    if ts.mint in state.blacklist:
        return False
    if len(state.positions) >= state.max_positions:
        return False
    if ts.mint in state.positions:
        return False
    return ts.score >= state.min_score_to_buy and ts.risk_score <= state.max_risk_to_buy


def should_auto_sell(pos: Position, state: BotState) -> Optional[str]:
    if not state.auto_sell_enabled:
        return None
    if pos.pnl_pct >= state.take_profit_pct:
        return "take_profit"
    if pos.pnl_pct <= -state.stop_loss_pct:
        return "stop_loss"
    return None


def execute_trade(action: str, mint: str, amount: str | float, denominated_in_sol: bool = True,
                  slippage: Optional[float] = None, priority_fee: Optional[float] = None,
                  pool: str = "auto") -> dict:
    slippage = slippage or DEFAULT_SLIPPAGE
    priority_fee = priority_fee or DEFAULT_PRIORITY_FEE

    payload = {
        "action": action,
        "mint": mint,
        "amount": amount,
        "denominatedInSol": str(denominated_in_sol).lower(),
        "slippage": slippage,
        "priorityFee": priority_fee,
        "pool": pool,
    }

    if not is_live():
        return {"mode": "paper", "ok": True, "payload": payload, "signature": None}

    resp = requests.post(TRADE_URL, json=payload, timeout=20)
    data = resp.json()
    return {"mode": "live", "ok": resp.ok and "errors" not in data, "response": data, "payload": payload}


def apply_paper_fill(action: str, mint: str, qty_or_sol: float, price_sol: float) -> dict:
    if action == "buy":
        sol_spent = qty_or_sol
        qty = (sol_spent / price_sol) if price_sol > 0 else 0.0
        if STATE.paper_cash_sol < sol_spent:
            return {"ok": False, "error": "Not enough paper SOL balance"}
        pos = STATE.positions.get(mint)
        if pos:
            total_cost = pos.avg_entry_sol * pos.qty + sol_spent
            pos.qty += qty
            pos.avg_entry_sol = total_cost / max(pos.qty, 1e-9)
            pos.last_price_sol = price_sol
        else:
            STATE.positions[mint] = Position(mint=mint, qty=qty, avg_entry_sol=price_sol, last_price_sol=price_sol)
        STATE.paper_cash_sol -= sol_spent
        STATE.trade_history.append({"ts": time.time(), "action": action, "mint": mint, "sol": sol_spent, "qty": qty, "price": price_sol})
        return {"ok": True, "qty": qty, "price": price_sol}

    if action == "sell":
        pos = STATE.positions.get(mint)
        if not pos:
            return {"ok": False, "error": "No open position"}
        pct = float(str(qty_or_sol).replace("%", "")) if isinstance(qty_or_sol, str) and "%" in qty_or_sol else None
        qty = pos.qty * (pct / 100.0) if pct is not None else float(qty_or_sol)
        qty = min(qty, pos.qty)
        sol_received = qty * price_sol
        pnl_sol = qty * (price_sol - pos.avg_entry_sol)
        STATE.realized_pnl_sol += pnl_sol
        pos.qty -= qty
        pos.last_price_sol = price_sol
        if pos.qty <= 1e-9:
            del STATE.positions[mint]
        STATE.paper_cash_sol += sol_received
        STATE.trade_history.append({"ts": time.time(), "action": action, "mint": mint, "sol": sol_received, "qty": qty, "price": price_sol, "pnl_sol": pnl_sol})
        return {"ok": True, "qty": qty, "price": price_sol, "pnl_sol": pnl_sol}

    return {"ok": False, "error": "Unsupported action"}


async def maybe_trade(ts: TokenState, context: Optional[ContextTypes.DEFAULT_TYPE] = None) -> None:
    if should_auto_buy(ts, STATE):
        result = execute_trade("buy", ts.mint, DEFAULT_BUY_SOL, denominated_in_sol=True)
        fill = apply_paper_fill("buy", ts.mint, DEFAULT_BUY_SOL, ts.last_price_sol or 0.0000001)
        logger.info("AUTO BUY %s | %s | %s", ts.mint, result, fill)

    pos = STATE.positions.get(ts.mint)
    if pos and pos.avg_entry_sol > 0:
        pos.last_price_sol = ts.last_price_sol or pos.last_price_sol
        pos.pnl_pct = ((pos.last_price_sol - pos.avg_entry_sol) / pos.avg_entry_sol) * 100.0
        sell_reason = should_auto_sell(pos, STATE)
        if sell_reason:
            result = execute_trade("sell", ts.mint, "100%", denominated_in_sol=False)
            fill = apply_paper_fill("sell", ts.mint, "100%", ts.last_price_sol or pos.last_price_sol)
            logger.info("AUTO SELL %s | %s | %s | %s", ts.mint, sell_reason, result, fill)


# =========================
# Websocket listener
# =========================
async def stream_pump_data() -> None:
    while True:
        try:
            async with websockets.connect(WS_URL, ping_interval=20, ping_timeout=20) as ws:
                await ws.send(json.dumps({"method": "subscribeNewToken"}))
                logger.info("Subscribed to new token stream")
                async for raw in ws:
                    try:
                        data = json.loads(raw)
                    except json.JSONDecodeError:
                        continue

                    mint = data.get("mint") or data.get("ca") or data.get("tokenAddress")
                    if not mint:
                        continue

                    ts = STATE.watchlist.get(mint)
                    if not ts:
                        ts = TokenState(
                            mint=mint,
                            symbol=data.get("symbol", "?"),
                            name=data.get("name", "Unknown"),
                        )
                        STATE.watchlist[mint] = ts

                    tx_type = (data.get("txType") or data.get("tradeType") or data.get("action") or "").lower()
                    wallet = data.get("traderPublicKey") or data.get("wallet") or data.get("user") or "unknown"
                    amount_sol = float(data.get("solAmount") or data.get("amountSol") or 0.0)
                    price_sol = float(data.get("priceSol") or data.get("price") or 0.0)
                    market_cap = float(data.get("marketCapSol") or data.get("marketCap") or 0.0)

                    ts.trade_count += 1
                    ts.last_price_sol = price_sol or ts.last_price_sol
                    ts.market_cap = market_cap or ts.market_cap
                    ts.unique_wallets.add(wallet)
                    ts.recent_trades.append(data)

                    if tx_type == "buy":
                        ts.buy_count += 1
                        ts.wallet_buy_volume[wallet] += amount_sol
                    elif tx_type == "sell":
                        ts.sell_count += 1
                        ts.wallet_sell_volume[wallet] += amount_sol

                    compute_risk_and_score(ts, STATE)
                    await maybe_trade(ts)
        except asyncio.CancelledError:
            raise
        except Exception as e:
            logger.exception("Stream error: %s", e)
            await asyncio.sleep(3)


