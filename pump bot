async def scan(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    best = sorted(STATE.watchlist.values(), key=lambda x: (x.score, -x.risk_score), reverse=True)[:10]
    if not best:
        await send_text(update, "No tokens tracked yet. Wait for websocket data.")
        return
    lines = [format_token(t) for t in best]
    await send_text(update, "\n\n".join(lines))


async def trending(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    await scan(update, context)


