# DATA MODELS
# =========================================================

@dataclass
class TokenSnapshot:
    symbol: str
    mint: str
    timestamp: int

    # Market / chart
    price: float
    market_cap: float
    liquidity_usd: float
    volume_5m_usd: float
    volume_1h_usd: float

    # Holder / wallet behavior
    top10_holder_pct: float
    creator_holder_pct: float
    fresh_wallet_buy_pct: float
    whale_sell_count_5m: int
    whale_buy_count_5m: int

    # Trade behavior
    buys_5m: int
    sells_5m: int
    unique_buyers_5m: int
    unique_sellers_5m: int

    # Safety flags
    can_sell: bool = True
    has_freeze_authority: bool = False
    has_mint_authority: bool = False
    liquidity_locked: bool = True
    contract_verified: bool = True


@dataclass
class Position:
    mint: str
    symbol: str
    entry_price: float
    entry_time: int
    size_usd: float

    highest_price: float
    remaining_pct: float = 1.0

    sold_25_tp1: bool = False
    sold_25_tp2: bool = False
    sold_25_tp3: bool = False

    notes: List[str] = field(default_factory=list)


# =========================================================
# CONFIG
# =========================================================

@dataclass
class StrategyConfig:
    # Entry / analysis
    min_liquidity_usd: float = 12000
    min_volume_5m_usd: float = 2500
    min_unique_buyers_5m: int = 18
    max_top10_holder_pct: float = 35.0
    max_creator_holder_pct: float = 8.0
    min_buy_sell_ratio: float = 1.15

    # Hard safety
    reject_if_cannot_sell: bool = True
    reject_if_freeze_authority: bool = True
    reject_if_mint_authority: bool = True
    reject_if_liquidity_unlocked: bool = True

    # Sell logic
    hard_stop_loss_pct: float = 10.0       # full exit if price drops 10% from entry
    trailing_stop_pct: float = 12.0        # full exit if price falls 12% from highest
    whale_dump_trigger: int = 4            # if many whale sells occur fast -> reduce / exit
    severe_holder_concentration_pct: float = 45.0

    # Take profit ladder
    tp1_pct: float = 25.0                  # sell 25% at +25%
    tp2_pct: float = 50.0                  # sell 25% at +50%
    tp3_pct: float = 100.0                 # sell 25% at +100%
    moonbag_pct: float = 25.0              # keep last 25% for trailing

    # Scoring
    min_entry_score: int = 70


# =========================================================
# ANALYZER
# =========================================================

class EarlyAnalyzer:
    def __init__(self, config: StrategyConfig):
        self.config = config

    def analyze(self, snap: TokenSnapshot) -> Dict[str, object]:
        """
        Returns:
            {
                "score": int,
                "passed": bool,
                "reasons": [str, ...]
            }
        """
        reasons: List[str] = []
        score = 100

        # ---------- hard reject rules ----------
        if self.config.reject_if_cannot_sell and not snap.can_sell:
            return {
                "score": 0,
                "passed": False,
                "reasons": ["Hard reject: token currently cannot be sold."]
            }

        if self.config.reject_if_freeze_authority and snap.has_freeze_authority:
            return {
                "score": 0,
                "passed": False,
                "reasons": ["Hard reject: freeze authority present."]
            }

        if self.config.reject_if_mint_authority and snap.has_mint_authority:
            return {
                "score": 0,
                "passed": False,
                "reasons": ["Hard reject: mint authority present."]
            }

        if self.config.reject_if_liquidity_unlocked and not snap.liquidity_locked:
            return {
                "score": 0,
                "passed": False,
                "reasons": ["Hard reject: liquidity not locked."]
            }

        # ---------- liquidity ----------
        if snap.liquidity_usd < self.config.min_liquidity_usd:
            penalty = min(30, int((self.config.min_liquidity_usd - snap.liquidity_usd) / 500))
            score -= penalty
            reasons.append(f"Weak liquidity: ${snap.liquidity_usd:,.0f}")

        # ---------- volume ----------
        if snap.volume_5m_usd < self.config.min_volume_5m_usd:
            penalty = min(20, int((self.config.min_volume_5m_usd - snap.volume_5m_usd) / 250))
            score -= penalty
            reasons.append(f"Low 5m volume: ${snap.volume_5m_usd:,.0f}")

        # ---------- buyer strength ----------
        if snap.unique_buyers_5m < self.config.min_unique_buyers_5m:
            penalty = min(20, (self.config.min_unique_buyers_5m - snap.unique_buyers_5m) * 2)
            score -= penalty
            reasons.append(f"Too few unique buyers: {snap.unique_buyers_5m}")

        buy_sell_ratio = self._safe_div(snap.buys_5m, max(1, snap.sells_5m))
        if buy_sell_ratio < self.config.min_buy_sell_ratio:
            score -= 12
            reasons.append(f"Buy/sell ratio weak: {buy_sell_ratio:.2f}")

        # ---------- holder concentration ----------
        if snap.top10_holder_pct > self.config.max_top10_holder_pct:
            penalty = min(25, int((snap.top10_holder_pct - self.config.max_top10_holder_pct) * 1.2))
            score -= penalty
            reasons.append(f"Top10 concentration high: {snap.top10_holder_pct:.1f}%")

        if snap.creator_holder_pct > self.config.max_creator_holder_pct:
            penalty = min(20, int((snap.creator_holder_pct - self.config.max_creator_holder_pct) * 2))
            score -= penalty
            reasons.append(f"Creator allocation high: {snap.creator_holder_pct:.1f}%")

        # ---------- whale behavior ----------
        whale_delta = snap.whale_buy_count_5m - snap.whale_sell_count_5m
        if whale_delta < 0:
            score -= min(15, abs(whale_delta) * 3)
            reasons.append(
                f"Whales selling more than buying ({snap.whale_sell_count_5m} sells vs {snap.whale_buy_count_5m} buys)"
            )

        # ---------- fresh wallet distribution ----------
        # Some fresh-wallet activity can be good, too much can be suspicious.
        if snap.fresh_wallet_buy_pct > 65:
            score -= 8
            reasons.append(f"Fresh-wallet participation unusually high: {snap.fresh_wallet_buy_pct:.1f}%")
        elif 20 <= snap.fresh_wallet_buy_pct <= 50:
            score += 3

        # ---------- contract quality ----------
        if not snap.contract_verified:
            score -= 8
            reasons.append("Contract not verified.")

        score = max(0, min(100, score))
        passed = score >= self.config.min_entry_score

        if passed and not reasons:
            reasons.append("Healthy early metrics detected.")

        return {
            "score": score,
            "passed": passed,
            "reasons": reasons
        }

    @staticmethod
    def _safe_div(a: float, b: float) -> float:
        return a / b if b else 0.0


# =========================================================
# SELL ENGINE
# =========================================================

class SafeSellEngine:
    def __init__(self, config: StrategyConfig):
        self.config = config

    def evaluate(self, position: Position, snap: TokenSnapshot) -> Dict[str, object]:
        """
        Returns an action:
            HOLD
            SELL_25
            SELL_50
            SELL_ALL

        with reasons.
        """
        reasons: List[str] = []
        action = "HOLD"
        sell_pct = 0.0

        # update highest price seen
        if snap.price > position.highest_price:
            position.highest_price = snap.price

        pnl_pct = self.percent_change(position.entry_price, snap.price)
        drawdown_from_high_pct = self.percent_drop(position.highest_price, snap.price)

        # ---------- hard stop loss ----------
        if pnl_pct <= -self.config.hard_stop_loss_pct:
            return {
                "action": "SELL_ALL",
                "sell_pct": 100.0 * position.remaining_pct,
                "reasons": [f"Hard stop loss hit: {pnl_pct:.2f}% from entry."]
            }

        # ---------- cannot sell / critical safety ----------
        if not snap.can_sell:
            return {
                "action": "SELL_ALL",
                "sell_pct": 100.0 * position.remaining_pct,
                "reasons": ["Emergency exit: token sellability turned unsafe."]
            }

        if snap.top10_holder_pct >= self.config.severe_holder_concentration_pct:
            reasons.append(
                f"Severe holder concentration: top10={snap.top10_holder_pct:.1f}%"
            )
            action = "SELL_ALL"
            sell_pct = 100.0 * position.remaining_pct

        # ---------- whale dump detection ----------
        if snap.whale_sell_count_5m >= self.config.whale_dump_trigger:
            if position.remaining_pct > 0.50:
                action = "SELL_50"
                sell_pct = 50.0
            else:
                action = "SELL_ALL"
                sell_pct = 100.0 * position.remaining_pct
            reasons.append(f"Whale dump warning: {snap.whale_sell_count_5m} whale sells in 5m.")

        # ---------- take-profit ladder ----------
        if pnl_pct >= self.config.tp1_pct and not position.sold_25_tp1:
            action, sell_pct = "SELL_25", 25.0
            reasons.append(f"TP1 reached: +{pnl_pct:.2f}%")

        if pnl_pct >= self.config.tp2_pct and not position.sold_25_tp2:
            action, sell_pct = "SELL_25", 25.0
            reasons.append(f"TP2 reached: +{pnl_pct:.2f}%")

        if pnl_pct >= self.config.tp3_pct and not position.sold_25_tp3:
            action, sell_pct = "SELL_25", 25.0
            reasons.append(f"TP3 reached: +{pnl_pct:.2f}%")

        # ---------- trailing stop for remaining size ----------
        if drawdown_from_high_pct >= self.config.trailing_stop_pct and pnl_pct > 0:
            action = "SELL_ALL"
            sell_pct = 100.0 * position.remaining_pct
            reasons.append(
                f"Trailing stop hit: {drawdown_from_high_pct:.2f}% off peak after profit."
            )

        # ---------- weakening order flow ----------
        buy_sell_ratio = snap.buys_5m / max(1, snap.sells_5m)
        if pnl_pct > 15 and buy_sell_ratio < 0.9 and snap.unique_sellers_5m > snap.unique_buyers_5m:
            if position.remaining_pct > 0.5 and action == "HOLD":
                action = "SELL_25"
                sell_pct = 25.0
                reasons.append("Momentum weakening: sellers overtaking buyers.")

        if not reasons:
            reasons.append("No sell trigger hit.")

        return {
            "action": action,
            "sell_pct": sell_pct,
            "reasons": reasons
        }

    @staticmethod
    def percent_change(entry: float, current: float) -> float:
        if entry <= 0:
            return 0.0
        return ((current - entry) / entry) * 100.0

    @staticmethod
    def percent_drop(high: float, current: float) -> float:
        if high <= 0:
            return 0.0
        return ((high - current) / high) * 100.0

    def apply_action(self, position: Position, result: Dict[str, object]) -> None:
        action = result["action"]
        sell_pct = float(result["sell_pct"])
        reason_text = " | ".join(result["reasons"])

        if action == "SELL_25":
            reduction = 0.25
            position.remaining_pct = max(0.0, position.remaining_pct - reduction)

            # mark TP stages in order
            if not position.sold_25_tp1:
                position.sold_25_tp1 = True
            elif not position.sold_25_tp2:
                position.sold_25_tp2 = True
            elif not position.sold_25_tp3:
                position.sold_25_tp3 = True

            position.notes.append(f"SELL_25 executed: {reason_text}")

        elif action == "SELL_50":
            reduction = 0.50
            position.remaining_pct = max(0.0, position.remaining_pct - reduction)
            position.notes.append(f"SELL_50 executed: {reason_text}")

        elif action == "SELL_ALL":
            position.remaining_pct = 0.0
            position.notes.append(f"SELL_ALL executed: {reason_text}")

        else:
            position.notes.append(f"HOLD: {reason_text}")


# =========================================================
# BOT / MANAGER
# =========================================================

class PaperTradeRiskBot:
    """
    Analysis + alert bot.
    Keeps track of candidate tokens and positions.
    """

    def __init__(self, config: StrategyConfig):
        self.config = config
        self.analyzer = EarlyAnalyzer(config)
        self.seller = SafeSellEngine(config)
        self.positions: Dict[str, Position] = {}

    def early_analysis(self, snap: TokenSnapshot) -> Dict[str, object]:
        result = self.analyzer.analyze(snap)

        return {
            "symbol": snap.symbol,
            "mint": snap.mint,
            "score": result["score"],
            "passed": result["passed"],
            "reasons": result["reasons"]
        }

    def open_paper_position(self, snap: TokenSnapshot, size_usd: float = 100.0) -> Tuple[bool, str]:
        analysis = self.analyzer.analyze(snap)

        if not analysis["passed"]:
            return False, f"Rejected {snap.symbol}: " + "; ".join(analysis["reasons"])

        if snap.mint in self.positions and self.positions[snap.mint].remaining_pct > 0:
            return False, f"Position already exists for {snap.symbol}"

        self.positions[snap.mint] = Position(
            mint=snap.mint,
            symbol=snap.symbol,
            entry_price=snap.price,
            entry_time=snap.timestamp,
            size_usd=size_usd,
            highest_price=snap.price,
        )
        return True, f"Paper position opened on {snap.symbol} at {snap.price:.8f}"

    def update_position(self, snap: TokenSnapshot) -> Optional[Dict[str, object]]:
        pos = self.positions.get(snap.mint)
        if not pos or pos.remaining_pct <= 0:
            return None

        result = self.seller.evaluate(pos, snap)
        self.seller.apply_action(pos, result)

        return {
            "symbol": pos.symbol,
            "action": result["action"],
            "sell_pct": result["sell_pct"],
            "remaining_pct": round(pos.remaining_pct * 100.0, 2),
            "reasons": result["reasons"],
            "entry_price": pos.entry_price,
            "current_price": snap.price,
            "highest_price": pos.highest_price
        }


