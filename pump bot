@dataclass
class Position:
    mint: str
    qty: float = 0.0
    avg_entry_sol: float = 0.0
    last_price_sol: float = 0.0
    pnl_pct: float = 0.0
    opened_at: float = field(default_factory=time.time)


@dataclass
class TokenState:
    mint: str
    symbol: str = "?"
    name: str = "Unknown"
    created_at: float = field(default_factory=time.time)
    last_price_sol: float = 0.0
    market_cap: float = 0.0
    buy_count: int = 0
    sell_count: int = 0
    trade_count: int = 0
    unique_wallets: set = field(default_factory=set)
    recent_trades: Deque[dict] = field(default_factory=lambda: deque(maxlen=200))
    wallet_buy_volume: Dict[str, float] = field(default_factory=lambda: defaultdict(float))
    wallet_sell_volume: Dict[str, float] = field(default_factory=lambda: defaultdict(float))
    score: float = 0.0
    risk_score: float = 100.0
    notes: List[str] = field(default_factory=list)


class BotState:
    def __init__(self) -> None:
        self.watchlist: Dict[str, TokenState] = {}
        self.positions: Dict[str, Position] = {}
        self.paper_cash_sol: float = 5.0
        self.realized_pnl_sol: float = 0.0
        self.trade_history: List[dict] = []
        self.tracked_wallet_dump_count: Dict[str, int] = defaultdict(int)
        self.paused: bool = False
        self.auto_buy_enabled: bool = False
        self.auto_sell_enabled: bool = True
        self.max_positions: int = 3
        self.min_score_to_buy: float = 65.0
        self.max_risk_to_buy: float = 40.0
        self.take_profit_pct: float = 25.0
        self.stop_loss_pct: float = 15.0
        self.trailing_stop_pct: float = 12.0
        self.risk_mode: str = "balanced"
        self.whitelist: set = set()
        self.blacklist: set = set()
        self.open_orders: List[dict] = []
        self.ws_task: Optional[asyncio.Task] = None


