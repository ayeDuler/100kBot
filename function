BUY_AMOUNT_SOL = 0.02
MAX_OPEN_POSITIONS = 3
MAX_POSITION_PER_TOKEN_SOL = 0.03
SLIPPAGE_BPS_PERCENT = 12
PRIORITY_FEE_SOL = 0.00005
POOL = "auto"

# Entry controls
MIN_SCORE_TO_ALERT = 70
MIN_SCORE_TO_BUY = 88
MIN_ALERT_AGE_SECONDS = 10
TRACK_SECONDS = 90
REBUY_COOLDOWN_SECONDS = 1800

# Position management
STOP_LOSS_PCT = 0.18          # sell if est. price falls 18% from entry
TAKE_PROFIT_PCT = 0.35        # partial/full take profit trigger
TRAILING_STOP_PCT = 0.12      # after token moves up, trail 12% off peak
FORCE_EXIT_SELL_PRESSURE = True

# Scanner thresholds
MIN_UNIQUE_BUYERS = 8
MIN_BUY_COUNT = 12
TOKEN_FINALIZE_AGE_SECONDS = 180
TOKEN_CLEANUP_AGE_SECONDS = 600
MAX_SINGLE_WALLET_SHARE_HEALTHY = 0.28

